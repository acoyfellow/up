{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "up-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "TEAM_DOMAIN": "https://test.cloudflareaccess.com",
    "POLICY_AUD": "test-audience",
    "ADMIN_EMAILS": "admin@example.com",
    "CONTROL_HOST": "control.example.com",
    "SITE_DOMAIN": "up.example.com",
    "MAX_SITE_BYTES": "52428800",
    "MAX_FILE_BYTES": "10485760",
    "MAX_FILES": "500",
    "SESSION_SECRET": "test-session-secret-that-is-at-least-32-characters",
    "SECRETS_KEY": "dGVzdC10ZXN0LXNlY3JldHMta2V5LTMyLWJ5dGVzISE"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "REGISTRY",
        "class_name": "UpRegistry"
      },
      {
        "name": "SITE_DATABASE",
        "class_name": "SiteDatabase"
      },
      {
        "name": "SITE_REALTIME",
        "class_name": "SiteRealtime"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["UpRegistry"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["SiteDatabase"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["SiteSecrets"]
    },
    {
      "tag": "v4"
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["SiteRealtime"]
    },
    {
      "tag": "v6",
      "deleted_classes": ["SiteSecrets"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "up-test-assets"
    }
  ]
}
