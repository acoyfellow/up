{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inhouse-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "TEAM_DOMAIN": "https://test.cloudflareaccess.com",
    "POLICY_AUD": "test-audience",
    "ADMIN_EMAILS": "admin@example.com",
    "CONTROL_HOST": "control.example.com",
    "SITE_DOMAIN": "inhouse.example.com",
    "MAX_SITE_BYTES": "52428800",
    "MAX_FILE_BYTES": "10485760",
    "MAX_FILES": "500",
    "SESSION_SECRET": "test-session-secret-that-is-at-least-32-characters"
  },
  "durable_objects": {
    "bindings": [
      { "name": "REGISTRY", "class_name": "InhouseRegistry" },
      { "name": "SITE_DATABASE", "class_name": "SiteDatabase" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["InhouseRegistry"] },
    { "tag": "v2", "new_sqlite_classes": ["SiteDatabase"] }
  ],
  "r2_buckets": [{ "binding": "ASSETS", "bucket_name": "inhouse-test-assets" }]
}
