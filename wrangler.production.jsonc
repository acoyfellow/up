{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "up",
  "main": "build/worker.bundled.mjs",
  "compatibility_date": "2026-06-12",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "preview_urls": false,
  "observability": { "enabled": true },
  "build": { "command": "bun run build" },
  "routes": [
    { "pattern": "up.example.com", "custom_domain": true },
    { "pattern": "*.up.example.com/*", "zone_name": "up.example.com" }
  ],
  "vars": {
    "TEAM_DOMAIN": "https://REPLACE.cloudflareaccess.com",
    "POLICY_AUD": "REPLACE",
    "ADMIN_EMAILS": "admin@example.com",
    "CONTROL_HOST": "up.example.com",
    "SITE_DOMAIN": "up.example.com",
    "MAX_SITE_BYTES": "52428800",
    "MAX_FILE_BYTES": "10485760",
    "MAX_FILES": "500"
  },
  "durable_objects": { "bindings": [{ "name": "REGISTRY", "class_name": "InhouseRegistry" }] },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["InhouseRegistry"] }],
  "r2_buckets": [{ "binding": "ASSETS", "bucket_name": "up-assets" }],
  "worker_loaders": [{ "binding": "LOADER" }]
}
