{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "files": {
    "includes": [
      "**",
      "!build",
      "!.svelte-kit",
      "!dist",
      "!node_modules",
      "!.wrangler",
      "!src/*.generated.ts",
      "!src/**/*.svelte",
      "!public/**/*.svg",
      "!scratch"
    ]
  }
}
